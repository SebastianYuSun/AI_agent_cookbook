# Copy this file to .env and fill in your credentials.
# .env is gitignored and will NEVER be committed.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
# Method A — Bearer Token (recommended, introduced July 2025)
#   Simpler: single token, no signing required.
#   Limitation: does NOT support streaming.
#   Get yours: AWS Console → Bedrock → API keys
AWS_BEARER_TOKEN_BEDROCK=...
AWS_REGION_NAME=us-east-1

# Method B — IAM credentials (traditional)
#   Required if you need streaming, Bedrock Agents, or Data Automation.
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION_NAME=us-east-1

# ── Google Cloud (Gemini API) ──────────────────────────────────────────────────
GOOGLE_API_KEY=AIza...
