# Copy this file to .env and fill in your credentials.
# .env is gitignored and will NEVER be committed.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o                  # optional override

# ── AWS Bedrock (Claude) ───────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0   # optional override

# ── Google Cloud (Gemini API) ──────────────────────────────────────────────────
GOOGLE_API_KEY=AIza...
GOOGLE_MODEL=gemini-1.5-pro          # optional override

# ── Google Cloud (Vertex AI — alternative to Gemini API key) ──────────────────
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service_account.json
